generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  lastname  String
  email     String   @unique
  password  String
  token     String?
  createdAt DateTime @default(now())
  tasks     Task[]

  @@map("users")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  estado      String   @default("pendiente")
  createdAt   DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@map("tasks")
}